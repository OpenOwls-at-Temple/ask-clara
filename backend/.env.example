# LLM provider — set to anthropic, gemini, or deepseek (or mock: no-network
# canned responses for Playwright E2E; only works with ENVIRONMENT=local)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clara
MONGODB_URI=mongodb://localhost:27017/clara
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
JWT_SECRET=change-me-to-a-long-random-secret
ALLOWED_EMAIL_DOMAIN=temple.edu
ENVIRONMENT=local
FRONTEND_ORIGIN=http://localhost:5173

# Phase 2 — job-leads scan trigger (GitHub Actions workflow shared secret)
SCAN_TRIGGER_SECRET=change-me-to-a-long-random-secret

# E2E only — enables POST /auth/test-login (local environment required; the
# endpoint 404s otherwise). Never set in staging/prod.
TEST_LOGIN_SECRET=e2e-local-secret
